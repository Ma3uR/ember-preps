# --- Anthropic ---
# Required for U4 (MCP host) and U7 (LangChain agent, stretch).
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
# Required for U2 (db access), U3 (MCP server tools), U7 (LangChain tools).
#
# Two modes:
#   1. `supabase start` (local Docker stack)   — defaults below work as-is
#      after `supabase db reset` applies the migrations under supabase/.
#   2. Cloud Supabase project                  — replace each value with
#      what `supabase status` / the dashboard show, and edit
#      supabase/migrations/20260527000002_llm_readonly_role.sql to use a
#      generated password instead of `local_dev_password`.

# Public API URL. Local default: http://127.0.0.1:54321
SUPABASE_URL=http://127.0.0.1:54321

# Service-role key (server-side ONLY — bypasses RLS). Local default is shown
# by `supabase status` as `service_role key`. Used only by scripts/seed.ts.
SUPABASE_SERVICE_ROLE_KEY=

# pg connection string for the `llm_readonly` role. Local default uses
# Supabase CLI's direct-db port (54322) and the password the migration sets.
SUPABASE_LLM_READONLY_DB_URL=postgresql://llm_readonly:local_dev_password@127.0.0.1:54322/postgres

# --- Backend toggle ---
# `mcp`      → UI posts only to /api/chat-mcp (default).
# `langchain`→ UI posts only to /api/chat-langchain.
# `compare`  → UI fires both backends in parallel and renders a side-by-side
#              comparison block per question (each question is single-shot).
BACKEND_MODE=mcp

# Client-side mirror so the UI knows which route(s) to POST to.
NEXT_PUBLIC_BACKEND_MODE=mcp
