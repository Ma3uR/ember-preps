# --- Anthropic ---
# Required for U4 (MCP host) and U7 (LangChain agent, stretch).
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
# Required for U2 (db access), U3 (MCP server tools), U7 (LangChain tools).

# Public project URL, e.g. https://xxxxx.supabase.co
SUPABASE_URL=

# Service-role key (server-side ONLY — bypasses RLS). Used by the MCP server
# when calling supabase.rpc('run_sql'). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for the `llm_readonly` role. Used by the
# MCP server's `pg` client path (if chosen over the supabase-js rpc path).
# Generate the password during U2 with: openssl rand -base64 24
SUPABASE_LLM_READONLY_DB_URL=postgres://llm_readonly:<password>@<host>:5432/postgres

# --- Backend toggle ---
# Stage 1 = mcp, stage 2 = langchain. Default `mcp`.
BACKEND_MODE=mcp

# Client-side mirror so the UI knows which route to POST to.
NEXT_PUBLIC_BACKEND_MODE=mcp
